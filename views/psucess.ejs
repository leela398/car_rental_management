<html>
  <head>
    <title>Payment Successful - APEX DRIVE</title>
    <style>
      body {
          text-align: center;
          background: #f8fafc;
          font-family: "Inter", sans-serif;
          color: #0f172a;
          margin: 0;
          padding: 0;
          display: flex;
          justify-content: center;
          align-items: center;
          height: 100vh;
      }
      h1 {
          color: #10b981;
          font-weight: 800;
          font-size: 32px;
          margin-bottom: 10px;
          margin-top: 20px;
      }
      p {
          color: #475569;
          font-size: 16px;
          margin: 0 0 25px 0;
          line-height: 1.5;
      }
      .card {
          background: #ffffff;
          padding: 50px 40px;
          border-radius: 16px;
          border: 1px solid #e2e8f0;
          box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
          display: inline-block;
          max-width: 400px;
          width: 90%;
      }
      .checkmark-circle {
          border-radius: 50%;
          height: 100px;
          width: 100px;
          background: #f0fdf4;
          border: 1px solid #bfepm = #dcfce7;
          display: flex;
          justify-content: center;
          align-items: center;
          margin: 0 auto;
      }
      .checkmark {
          color: #10b981;
          font-size: 50px;
          font-style: normal;
          font-weight: bold;
      }
      #back {
          width: 100%;
          height: 46px;
          background: #0f172a;
          border: none;
          font-size: 15px;
          font-weight: bold;
          border-radius: 8px;
          cursor: pointer;
          transition: 0.2s;
      }
      #back:hover {
          background: #1e293b;
      }
      #back a {
          text-decoration: none;
          color: #ffffff;
          display: flex;
          align-items: center;
          justify-content: center;
          width: 100%;
          height: 100%;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="checkmark-circle">
        <span class="checkmark">✓</span>
      </div>
      <h1>Success</h1> 
      <p>We received your rental request;<br/> we'll be in touch shortly!</p>
      <button id="back"><a href="/cardetails">Search Cars</a></button>
    </div>
  </body>
</html>
