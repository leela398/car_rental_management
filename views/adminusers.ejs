<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ADMINISTRATOR - APEX DRIVE</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-page">
<div class="main">
        <div class="navbar">
            <div class="icon">
                <h2 class="logo">APEX</h2>
            </div>
            <div class="menu">
                <ul>
                    <li><a href="/adminvehicle">VEHICLE MANAGEMENT</a></li>
                    <li><a href="/adminusers">USERS</a></li>
                    <li><a href="/admindash">FEEDBACKS</a></li>
                    <li><a href="/adminbook">BOOKING REQUEST</a></li>
                    <li><button class="nn"><a href="/logout">LOGOUT</a></button></li>
                </ul>
            </div>
        </div>
        <div>
            <h1 class="header">USERS</h1>
            <div>
                <div>
                    <table class="content-table">
                <thead>
                    <tr>
                        <th>NAME</th> 
                        <th>EMAIL</th>
                        <th>LICENSE NUMBER</th>
                        <th>PHONE NUMBER</th> 
                        <th>GENDER</th> 
                        <th>DELETE USERS</th>
                    </tr>
                </thead>
                <tbody>
                <% if (users && users.length > 0) { %>
                    <% users.forEach(function(user) { %>
                        <tr class="active-row">
                            <td><%= user.fname %> <%= user.lname %></td>
                            <td><%= user.email %></td>
                            <td><%= user.lic_num %></td>
                            <td><%= user.phone_number %></td>
                            <td><%= user.gender %></td>
                            <td>
                                <button type="button" class="but">
                                    <a href="/deleteuser/<%= user.email %>" onclick="return confirm('Are you sure you want to delete this user?')">DELETE USER</a>
                                </button>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="6" style="text-align: center;">No users found.</td>
                    </tr>
                <% } %>
                </tbody>
                </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
