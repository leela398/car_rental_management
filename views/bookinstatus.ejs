<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BOOKING STATUS - APEX DRIVE</title>
    <style>
    *{
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    body{
        background: #f8fafc;
        font-family: "Inter", sans-serif;
        color: #0f172a;
    }
    .box{
        padding: 40px;
        background: #ffffff;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        display: flex;
        flex-direction: column;
        justify-content: center;
        width: 100%;
        max-width: 600px;
        margin: 40px auto;
    }
    .box .content h1{
        font-size: 20px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 12px;
        display: flex;
        justify-content: space-between;
        border-bottom: 1px solid #f1f5f9;
        padding-bottom: 8px;
    }
    .box .content h1 span {
        font-weight: 500;
        color: #475569;
    }
    .utton{
        width: 160px;
        height: 40px;
        background: #0f172a;
        border:none;
        font-size: 14px;
        border-radius: 6px;
        cursor: pointer;
        transition: 0.2s ease;
    }
    .utton:hover {
        background: #1e293b;
    }
    .utton a{
        text-decoration: none;
        color: white;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
    }
    ul{
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 600px;
        margin: 50px auto 10px auto;
        padding: 0 10px;
    }
    ul li{
        list-style: none;
    }
    .name{
        font-size: 18px;
        font-weight: 700;
        color: #0f172a;
    }
    </style>
</head>
<body>
    <ul>
        <li><button class="utton"><a href="/cardetails">Go to Home</a></button></li>
        <li class="name">HELLO, <%= user.fname.toUpperCase() %></li>
    </ul>

    <div class="box">
         <div class="content">
             <h1>CAR NAME: <span><%= booking.car_id ? booking.car_id.car_name : 'N/A' %></span></h1>
             <h1>NO OF DAYS: <span><%= booking.duration %></span></h1>
             <h1>TOTAL RENT: <span>₹<%= booking.price %>/-</span></h1>
             <h1>BOOKING STATUS: <span style="font-weight: 700; color: <%= booking.book_status === 'APPROVED' ? '#10b981' : (booking.book_status === 'RETURNED' ? '#3b82f6' : '#f59e0b') %>;"><%= booking.book_status %></span></h1>
         </div>
     </div>
</body>
</html>
