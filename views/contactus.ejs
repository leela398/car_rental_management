<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.2/css/all.min.css"/>
    <link rel="stylesheet" href="/css/style.css">
    <title>Contact Us - APEX DRIVE</title>
    <style>
        .contact-container {
            max-width: 900px;
            margin: 60px auto;
            padding: 40px;
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
            display: grid;
            grid-template-columns: 1.2fr 1fr;
            gap: 40px;
        }
        .contact-details h1 {
            font-size: 32px;
            color: #0f172a;
            margin-bottom: 15px;
        }
        .contact-details p {
            font-size: 15px;
            color: #475569;
            line-height: 1.6;
            margin-bottom: 30px;
        }
        .info-box {
            display: flex;
            align-items: flex-start;
            gap: 15px;
            margin-bottom: 25px;
        }
        .info-box .icon {
            font-size: 20px;
            color: #0f172a;
            background: #f8fafc;
            padding: 10px;
            border-radius: 8px;
            border: 1px solid #e2e8f0;
        }
        .info-box .text h3 {
            font-size: 16px;
            color: #0f172a;
            margin-bottom: 4px;
            font-weight: 600;
        }
        .info-box .text p {
            font-size: 14px;
            color: #475569;
            margin-bottom: 0;
            line-height: 1.5;
        }
        .contact-form h2 {
            font-size: 22px;
            color: #0f172a;
            margin-bottom: 20px;
            font-weight: 700;
        }
        .input-group {
            margin-bottom: 20px;
        }
        .input-group label {
            display: block;
            font-size: 13px;
            color: #475569;
            margin-bottom: 6px;
            font-weight: 500;
        }
        .input-group input, .input-group textarea {
            width: 100%;
            padding: 10px 14px;
            background: #f8fafc;
            border: 1px solid #cbd5e1;
            border-radius: 6px;
            color: #0f172a;
            font-size: 14px;
            outline: none;
            transition: 0.2s;
        }
        .input-group textarea {
            height: 100px;
            resize: none;
        }
        .input-group input:focus, .input-group textarea:focus {
            border-color: #0f172a;
            background: #ffffff;
            box-shadow: 0 0 0 2px rgba(15, 23, 42, 0.15);
        }
        .send-btn {
            width: 100%;
            height: 44px;
            background: #0f172a;
            color: #ffffff;
            border: none;
            font-size: 14px;
            font-weight: 600;
            border-radius: 6px;
            cursor: pointer;
            transition: 0.2s;
        }
        .send-btn:hover {
            background: #1e293b;
        }
    </style>
</head>
<body style="background: #f8fafc;">
    <div class="main" style="background: #f8fafc; min-height: auto;">
        <div class="navbar">
            <div class="icon">
                <h2 class="logo">APEX</h2>
            </div>
            <div class="menu">
                <ul>
                    <% if (user) { %>
                        <li><a href="/cardetails">HOME</a></li>
                        <li><a href="/about">ABOUT</a></li>
                        <li><a href="/contact">CONTACT</a></li>
                        <li><a href="/feedback">FEEDBACK</a></li>
                        <li><button class="nn"><a href="/logout">LOGOUT</a></button></li>
                    <% } else { %>
                        <li><a href="/">HOME</a></li>
                        <li><a href="/about">ABOUT</a></li>
                        <li><a href="/contact">CONTACT</a></li>
                        <li><button class="adminbtn"><a href="/adminlogin">ADMIN LOGIN</a></button></li>
                    <% } %>
                </ul>
            </div>
        </div>

        <div class="contact-container">
            <div class="contact-details">
                <h1>Contact Us</h1>
                <p>Have questions about bookings, pricing, or fleet availability? Get in touch with our team and we'll get back to you within 24 hours.</p>
                
                <div class="info-box">
                    <div class="icon"><i class="fas fa-map-marker-alt"></i></div>
                    <div class="text">
                        <h3>Address</h3>
                        <p>4671 Sugar Camp Road,<br>Owatonna, Minnesota, 55060</p>
                    </div>
                </div>

                <div class="info-box">
                    <div class="icon"><i class="fas fa-phone-alt"></i></div>
                    <div class="text">
                        <h3>Phone</h3>
                        <p>507-475-6094</p>
                    </div>
                </div>

                <div class="info-box">
                    <div class="icon"><i class="fas fa-envelope"></i></div>
                    <div class="text">
                        <h3>Email</h3>
                        <p>support@apexdrive.com</p>
                    </div>
                </div>
            </div>

            <div class="contact-form">
                <h2>Send Message</h2>
                <form onsubmit="alert('Message sent successfully! We will get back to you soon.'); return false;">
                    <div class="input-group">
                        <label>Full Name</label>
                        <input type="text" placeholder="Enter your full name" required>
                    </div>
                    <div class="input-group">
                        <label>Email</label>
                        <input type="email" placeholder="Enter your email" required>
                    </div>
                    <div class="input-group">
                        <label>Message</label>
                        <textarea placeholder="Type your message here..." required></textarea>
                    </div>
                    <button type="submit" class="send-btn">Send Message</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
