<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CANCEL BOOKING - APEX DRIVE</title>
    <style>
        body {
            background: #f8fafc;
            font-family: "Inter", sans-serif;
            color: #0f172a;
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }
        .card {
            background: #ffffff;
            padding: 40px;
            border-radius: 16px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
            max-width: 500px;
            width: 90%;
            text-align: center;
        }
        h1 {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 30px;
            line-height: 1.4;
            color: #0f172a;
        }
        .btn-container {
            display: flex;
            justify-content: center;
            gap: 20px;
        }
        .btn-cancel {
            width: 160px;
            height: 44px;
            background: #ef4444;
            border: none;
            color: #ffffff;
            font-size: 14px;
            font-weight: bold;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.2s;
        }
        .btn-cancel:hover {
            background: #dc2626;
        }
        .btn-back {
            width: 160px;
            height: 44px;
            background: #0f172a;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.2s;
        }
        .btn-back:hover {
            background: #1e293b;
        }
        .btn-back a {
            text-decoration: none;
            color: #ffffff;
            font-weight: bold;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 100%;
        }
    </style>
</head>
<body>
    <div class="card">
        <form method="POST" action="/cancelbooking">
            <h1>ARE YOU SURE YOU WANT TO CANCEL YOUR BOOKING?</h1>
            <div class="btn-container">
                <input type="submit" class="btn-cancel" value="YES, CANCEL NOW" name="cancelnow">
                <button type="button" class="btn-back"><a href="/payment">NO, GO BACK</a></button>
            </div>
        </form>
    </div>
</body>
</html>
