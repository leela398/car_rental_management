# Port that the server will bind to
PORT=3000

# MongoDB Connection URI
# Local: mongodb://127.0.0.1:27017/carproject
# Production (Atlas): mongodb+srv://<username>:<password>@cluster.mongodb.net/carproject
MONGODB_URI=mongodb://127.0.0.1:27017/carproject

# Express Session Secret (use a secure random string in production)
SESSION_SECRET=some_secure_random_string_here
